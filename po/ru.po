msgid "Select a language"
msgstr "Выберите язык"

#: setup/emojilang.py:70 setup/enginedialog.py:60 setup/keyboardshortcut.py:339
#: setup/main.py:643
msgid "_Cancel"
msgstr "О_тменить"

#: setup/emojilang.py:71 setup/keyboardshortcut.py:340 setup/main.py:644
msgid "_OK"
msgstr "_OK"

#: setup/emojilang.py:235 setup/enginedialog.py:224
msgid "More…"
msgstr "Больше…"

#: setup/engineabout.py:37 setup/setup.ui:1465 ui/gtk3/panel.vala:1683
msgid "About"
msgstr "О программе"

#: setup/engineabout.py:40 setup/setup.ui:1488
msgid "_Close"
