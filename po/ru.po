"IBus has been started. If you cannot use IBus, add the following lines to "
"your $HOME/.bashrc; then relog into your desktop.\n"
"\n"
"  # For Wayland sessions ($XDG_SESSION_TYPE is \"wayland\")\n"
"  export GTK_IM_MODULE=wayland\n"
"  export XMODIFIERS=@im=ibus\n"
"  export QT_IM_MODULES=wayland;ibus\n"
"  export QT_IM_MODULE=ibus\n"
"\n"
"  # For X11 sessions ($XDG_SESSION_TYPE is \"x11\")\n"
"  export GTK_IM_MODULE=ibus\n"
"  export XMODIFIERS=@im=ibus\n"
"  export QT_IM_MODULE=ibus"
msgstr ""
"IBus запущен. Если вы не можете использовать IBus, добавьте следующие строки "
"в $HOME/.bashrc, затем войдите в систему заново.\n"
"\n"
"  # Для сеансов Wayland ($XDG_SESSION_TYPE равен \"wayland\")\n"
"  export GTK_IM_MODULE=wayland\n"
"  export XMODIFIERS=@im=ibus\n"
"  export QT_IM_MODULES=wayland;ibus\n"
"  export QT_IM_MODULE=ibus\n"
"\n"
"  # Для сеансов X11 ($XDG_SESSION_TYPE равен \"x11\")\n"
"  export GTK_IM_MODULE=ibus\n"
"  export XMODIFIERS=@im=ibus\n"
"  export QT_IM_MODULE=ibus"

